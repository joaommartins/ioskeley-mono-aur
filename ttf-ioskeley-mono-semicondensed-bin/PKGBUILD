pkgname=ttf-ioskeley-mono-semicondensed-bin
pkgver=2.0.0.beta.1
pkgrel=1
pkgdesc='Custom Iosevka build tuned to mimic Berkeley Mono (SemiCondensed width)'
arch=('any')
url='https://github.com/ahatem/IoskeleyMono'
license=('OFL-1.1')
provides=('ttf-ioskeley-mono-semicondensed')
conflicts=('ttf-ioskeley-mono-semicondensed')

# renovate: datasource=github-releases depName=ahatem/IoskeleyMono
_tag='v2.0.0-beta.1'
source=(
    "IoskeleyMono-SemiCondensed-${pkgver}.zip::${url}/releases/download/${_tag}/IoskeleyMono-SemiCondensed.zip"
    "LICENSE::https://raw.githubusercontent.com/ahatem/IoskeleyMono/${_tag}/LICENSE"
)
sha256sums=(
    'a4dc4d0801892922e7b3572e69bd8c6f0aa0364da436c64fdcb3e1c21b74bdbc'
    'SKIP'
)

package() {
    install -d "${pkgdir}/usr/share/fonts/TTF"
    install -m644 Hinted/*.ttf "${pkgdir}/usr/share/fonts/TTF/"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
