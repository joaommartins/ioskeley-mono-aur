pkgname=ttf-ioskeley-mono-nerd-semicondensed-bin
pkgver=2.0.0.beta.1
pkgrel=1
pkgdesc='Custom Iosevka build tuned to mimic Berkeley Mono, patched with Nerd Font glyphs (SemiCondensed width)'
arch=('any')
url='https://github.com/ahatem/IoskeleyMono'
license=('OFL-1.1')
provides=('ttf-ioskeley-mono-nerd-semicondensed')
conflicts=('ttf-ioskeley-mono-nerd-semicondensed')

# renovate: datasource=github-releases depName=ahatem/IoskeleyMono
_tag='v2.0.0'
source=(
    "IoskeleyMono-NerdFont-SemiCondensed-${pkgver}.zip::${url}/releases/download/${_tag}/IoskeleyMono-NerdFont-SemiCondensed.zip"
    "LICENSE::https://raw.githubusercontent.com/ahatem/IoskeleyMono/${_tag}/LICENSE"
)
sha256sums=(
    'e4a56b4ad8546bfd77a506bec5fab285b9a83e1fcc3777dbe8eb9233abb586f2'
    'SKIP'
)

package() {
    install -d "${pkgdir}/usr/share/fonts/TTF"
    install -m644 *.ttf "${pkgdir}/usr/share/fonts/TTF/"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
